DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/austin_restaurants

# Texas mixed beverage gross receipts (statewide, filtered to target city)
TX_MIXED_BEVERAGE_URL=https://data.texas.gov/resource/naix-2893.json

# Austin Socrata endpoint (live, rolling 3-year window)
AUSTIN_INSPECTIONS_URL=https://data.austintexas.gov/resource/ecmv-9xxi.json

# Optional Socrata app token (higher rate limits)
SOCRATA_APP_TOKEN=

# Cities to ingest from the statewide TX mixed beverage dataset
TARGET_CITIES=AUSTIN

FLASK_ENV=development
FLASK_SECRET_KEY=change-me
